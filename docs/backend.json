
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Vendeur"] },
        "boutiqueId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Boutique": {
      "title": "Boutique",
      "description": "Represents a physical store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "name", "address"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the global catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "sellingPrice"]
    },
    "Stock": {
      "title": "Stock",
      "description": "Inventory level for a product in a specific boutique.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "boutiqueId": { "type": "string" },
        "quantity": { "type": "number" },
        "alertThreshold": { "type": "number" }
      },
      "required": ["productId", "quantity"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer record with credit management.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "creditLimit": { "type": "number" },
        "currentDebt": { "type": "number" }
      },
      "required": ["name"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profile data."
    },
    "/boutiques/{boutiqueId}": {
      "schema": { "$ref": "#/backend/entities/Boutique" },
      "description": "Boutique information."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Global product catalog."
    },
    "/boutiques/{boutiqueId}/stocks/{stockId}": {
      "schema": { "$ref": "#/backend/entities/Stock" },
      "description": "Stock levels per boutique."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Client database."
    },
    "/transfers/{transferId}": {
      "schema": { "type": "object", "properties": { "status": { "type": "string" } } },
      "description": "Stock transfer requests."
    }
  }
}
